// Clevar — multi-tenant CRM data model.
// Tenant isolation is enforced in Postgres by Row-Level Security (see
// prisma/migrations/0_init/migration.sql). Every tenant-scoped table carries
// workspaceId; each request runs inside a transaction that sets
// `app.workspace_id`, and RLS policies gate every row.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── Control plane (no RLS) ───────────────────────────

model User {
  id           String            @id @default(uuid()) @db.Uuid
  email        String            @unique
  passwordHash String            @map("password_hash")
  fullName     String            @map("full_name")
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  memberships  WorkspaceMember[]

  @@map("users")
}

model Workspace {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  slug        String            @unique
  plan        WorkspacePlan     @default(FREE)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  members     WorkspaceMember[]
  invitations Invitation[]
  companies   Company[]
  contacts    Contact[]
  pipelines   Pipeline[]
  stages      Stage[]
  deals       Deal[]
  notes       Note[]
  tasks       Task[]
  activityEvents ActivityEvent[]
  aiAgents      AiAgent[]
  aiConversations AiConversation[]
  aiMessages    AiMessage[]
  aiUsage       AiUsage[]
  credits       WorkspaceCredits?
  whatsappChannels WhatsAppChannel[]
  waWebChannels WaWebChannel[]
  webWidgets    WebWidget[]
  channelConnections ChannelConnection[]
  apiKeys       ApiKey[]
  webhooks      Webhook[]
  conversations Conversation[]
  messages      Message[]
  labels        Label[]
  conversationLabels ConversationLabel[]
  cannedResponses CannedResponse[]
  macros        Macro[]
  favorites     Favorite[]
  articleCategories ArticleCategory[]
  articles      Article[]
  workflows     Workflow[]
  workflowRuns  WorkflowRun[]
  customValues  WorkspaceCustomValue[]
  agentDocuments AgentDocument[]
  objectDefinitions ObjectDefinition[]
  customFieldDefs   CustomFieldDef[]
  customRecords     CustomRecord[]
  associationTypes   AssociationType[]
  recordAssociations RecordAssociation[]
  agentChunks       AgentChunk[]
  dealContacts      DealContact[]
  knowledgeSources  KnowledgeSource[]
  knowledgeChunks   KnowledgeChunk[]
  agentKnowledgeSources AgentKnowledgeSource[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model Invitation {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  email       String
  role        WorkspaceRole @default(MEMBER)
  tokenHash   String        @unique @map("token_hash")
  expiresAt   DateTime      @map("expires_at") @db.Timestamptz
  acceptedAt  DateTime?     @map("accepted_at") @db.Timestamptz
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("invitations")
}

// ─────────────────────────── Tenant plane (RLS) ───────────────────────────────

model Company {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  name         String
  domain       String?
  industry     String?
  customFields Json      @default("{}") @map("custom_fields")
  createdById  String?   @map("created_by_id") @db.Uuid
  updatedById  String?   @map("updated_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  deals        Deal[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, name])
  @@map("companies")
}

model Contact {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  companyId    String?   @map("company_id") @db.Uuid
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  email        String?
  phone        String? // normalized E.164, incl. country code
  jobTitle     String?   @map("job_title")
  tags            String[]  @default([]) // contact tags (GIN-indexed)
  ownerId         String?   @map("owner_id") @db.Uuid // assigned workspace member
  dnd             Boolean   @default(false) // do-not-disturb / messaging opt-out
  engagementScore Int       @default(0) @map("engagement_score")
  customFields Json      @default("{}") @map("custom_fields")
  createdById  String?   @map("created_by_id") @db.Uuid
  updatedById  String?   @map("updated_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  dealContacts DealContact[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, companyId])
  @@index([workspaceId, ownerId])
  @@index([tags], type: Gin)
  @@map("contacts")
}

model Pipeline {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String
  isDefault   Boolean   @default(false) @map("is_default")
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages      Stage[]
  deals       Deal[]

  @@index([workspaceId, position])
  @@map("pipelines")
}

model Stage {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  pipelineId  String    @map("pipeline_id") @db.Uuid
  name        String
  position    Int
  stageType   StageType @default(OPEN) @map("stage_type")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline    Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals       Deal[]

  @@index([workspaceId, pipelineId, position])
  @@map("stages")
}

model Deal {
  id              String     @id @default(uuid()) @db.Uuid
  workspaceId     String     @map("workspace_id") @db.Uuid
  pipelineId      String     @map("pipeline_id") @db.Uuid
  stageId         String     @map("stage_id") @db.Uuid
  companyId       String?    @map("company_id") @db.Uuid
  title           String
  amount          Decimal?   @db.Decimal(18, 2)
  currency        String     @default("USD") @db.Char(3)
  status          DealStatus @default(OPEN)
  expectedCloseAt DateTime?  @map("expected_close_at") @db.Date
  customFields    Json       @default("{}") @map("custom_fields")
  createdById     String?    @map("created_by_id") @db.Uuid
  updatedById     String?    @map("updated_by_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline        Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage           Stage      @relation(fields: [stageId], references: [id], onDelete: Restrict)
  company         Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  dealContacts    DealContact[]

  @@index([workspaceId, pipelineId, stageId])
  @@index([workspaceId, status])
  @@map("deals")
}

model Note {
  id           String     @id @default(uuid()) @db.Uuid
  workspaceId  String     @map("workspace_id") @db.Uuid
  parentType   ObjectType @map("parent_type")
  parentId     String     @map("parent_id") @db.Uuid
  body         String
  customFields Json       @default("{}") @map("custom_fields")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, parentType, parentId, createdAt])
  @@map("notes")
}

model Task {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @map("workspace_id") @db.Uuid
  title       String
  body        String?
  status      TaskStatus  @default(TODO)
  dueAt       DateTime?   @map("due_at") @db.Timestamptz
  assigneeId  String?     @map("assignee_id") @db.Uuid
  parentType   ObjectType? @map("parent_type")
  parentId     String?     @map("parent_id") @db.Uuid
  customFields Json        @default("{}") @map("custom_fields")
  createdById  String?     @map("created_by_id") @db.Uuid
  completedAt  DateTime?   @map("completed_at") @db.Timestamptz
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, dueAt])
  @@index([workspaceId, assigneeId, status])
  @@index([workspaceId, parentType, parentId])
  @@map("tasks")
}

model ActivityEvent {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String     @map("workspace_id") @db.Uuid
  parentType  ObjectType @map("parent_type")
  parentId    String     @map("parent_id") @db.Uuid
  type        String // created | updated | note | task_created | task_completed | stage_changed
  summary     String
  actorId     String?    @map("actor_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, parentType, parentId, createdAt])
  @@map("activity_events")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// ─────────────────────────── AI layer (tenant plane, RLS) ─────────────────────

model AiAgent {
  id           String           @id @default(uuid()) @db.Uuid
  workspaceId  String           @map("workspace_id") @db.Uuid
  name         String
  instructions String           @default("") // extra custom instructions
  model        String           @default("claude-haiku-4-5") @map("model")
  // Studio config — assembled into the system prompt at reply time.
  mode           String         @default("support") // sales | support | custom
  tone           String         @default("friendly") // preset key
  responseStyle  String         @default("balanced") @map("response_style") // concise | balanced | detailed
  objectives     String         @default("")
  constraints    String         @default("")
  greeting       String         @default("")
  temperature    Float          @default(0.5)
  handoffEnabled Boolean        @default(true) @map("handoff_enabled")
  handoffUserId  String?        @map("handoff_user_id") @db.Uuid
  rules          Json           @default("[]") // [{label, trigger, keywords?, action, note?}]
  actions        Json           @default("{}") // { close|assign|note|label|contactField: { enabled, guideline } }
  // Structured prompt config (design: docs/support-agent-rag-design.md §4)
  dos            Json           @default("[]") // string[] — "Always" guardrails
  donts          Json           @default("[]") // string[] — "Never" guardrails
  playbook       Json           @default("[]") // {scenario, response}[] — canned lines
  examples       Json           @default("[]") // {user, assistant}[] — few-shot pairs
  grounding      String         @default("strict") // strict | flexible | open
  refusalLine    String?        @map("refusal_line") // fixed off-topic refusal sentence
  languagePolicy String         @default("mirror") @map("language_policy") // mirror | fixed:<lang>
  // CRM personalization allowlist (§3.4a); empty = off. e.g. ["name","company","tags","openDeals"]
  profileFields  Json           @default("[]") @map("profile_fields")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?        @map("deleted_at") @db.Timestamptz
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations AiConversation[]
  documents     AgentDocument[]
  knowledgeSources AgentKnowledgeSource[]

  @@index([workspaceId, createdAt])
  @@map("ai_agents")
}

model AgentDocument {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  agentId     String    @map("agent_id") @db.Uuid
  title       String
  content     String
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent       AiAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  chunks      AgentChunk[]

  @@index([workspaceId, agentId])
  @@map("agent_documents")
}

// Workspace-shared knowledge source (text | file | url | site). Lifecycle:
// pending → processing → ready | failed. Attached to agents via
// AgentKnowledgeSource; chunks carry the retrieval indexes.
model KnowledgeSource {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  type         String // text | file | url | site
  title        String
  // type-specific: {url, crawl, queue, visited, pages, hashes} for url/site;
  // {text} for text; {filename, mime} for file; {legacy} for backfilled rows.
  config       Json      @default("{}")
  status       String    @default("pending") // pending | processing | ready | failed
  error        String?
  chunkCount   Int       @default(0) @map("chunk_count")
  tokenCount   Int       @default(0) @map("token_count")
  contentHash  String?   @map("content_hash")
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamptz
  recrawlEvery Int?      @map("recrawl_every") // hours; null = manual re-sync only
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks       KnowledgeChunk[]
  agents       AgentKnowledgeSource[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@map("knowledge_sources")
}

model KnowledgeChunk {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  sourceId    String   @map("source_id") @db.Uuid
  // Page-namespaced: pageNo * 1000 + chunkNo, so a re-crawled page replaces its
  // own block and idx±1 neighbor expansion stays within one page.
  idx         Int
  content     String
  // Cited back to the user: page URL (site crawls) / filename.
  sourceRef   String?  @map("source_ref")
  contextPrefix String? @map("context_prefix")
  tokenCount  Int      @default(0) @map("token_count")
  // voyage-3.5 embedding of contextPrefix + content; NULL until enrichment runs.
  embedding   Unsupported("vector(1024)")?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source      KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, idx])
  @@index([workspaceId])
  @@map("knowledge_chunks")
}

// Many-to-many: several agents can share one source.
model AgentKnowledgeSource {
  agentId     String          @map("agent_id") @db.Uuid
  sourceId    String          @map("source_id") @db.Uuid
  workspaceId String          @map("workspace_id") @db.Uuid
  agent       AiAgent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  source      KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([agentId, sourceId])
  @@index([sourceId])
  @@index([workspaceId])
  @@map("agent_knowledge_sources")
}

// Ingestion-time passages of a document. Retrieval ranks + returns the top-k
// chunks (small, digestible), never whole documents.
// LEGACY (superseded by KnowledgeSource/KnowledgeChunk in migration 33) — kept
// read-only one release, then dropped.
model AgentChunk {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  agentId     String        @map("agent_id") @db.Uuid
  documentId  String        @map("document_id") @db.Uuid
  idx         Int
  content     String
  // Contextual-Retrieval situating sentence (generated at ingest); indexed for
  // search (embedding + FTS) but never sent to the reply model.
  contextPrefix String?     @map("context_prefix")
  // voyage-3.5 embedding of contextPrefix + content; NULL until enrichment runs.
  embedding   Unsupported("vector(1024)")?
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document    AgentDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, agentId])
  @@index([documentId])
  @@map("agent_chunks")
}

model WorkspaceCredits {
  workspaceId  String    @id @map("workspace_id") @db.Uuid
  monthlyLimit Int       @default(1000) @map("monthly_limit")
  used         Int       @default(0)
  periodStart  DateTime  @default(now()) @map("period_start") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_credits")
}

model AiUsage {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  agentId        String?   @map("agent_id") @db.Uuid
  conversationId String?   @map("conversation_id") @db.Uuid
  credits        Int
  tokensIn       Int       @default(0) @map("tokens_in")
  tokensOut      Int       @default(0) @map("tokens_out")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("ai_usage")
}

model AiConversation {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @map("workspace_id") @db.Uuid
  agentId     String      @map("agent_id") @db.Uuid
  title       String      @default("New chat")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent       AiAgent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages    AiMessage[]

  @@index([workspaceId, agentId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(uuid()) @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  conversationId String         @map("conversation_id") @db.Uuid
  role           AiMessageRole
  content        String
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([workspaceId, conversationId, createdAt])
  @@map("ai_messages")
}

enum AiMessageRole {
  USER
  ASSISTANT
}

// ─────────────────────── Inbox / WhatsApp (channels + chat) ────────────────────

// Control-plane (NO RLS): the webhook resolves the workspace from phoneNumberId
// before any tenant context exists, so this routing/config table must be readable
// without app.workspace_id (same rationale as invitations).
model WhatsAppChannel {
  id                 String    @id @default(uuid()) @db.Uuid
  workspaceId        String    @map("workspace_id") @db.Uuid
  phoneNumberId      String    @unique @map("phone_number_id")
  wabaId             String?   @map("waba_id")
  displayName        String    @default("WhatsApp") @map("display_name")
  // How the number was onboarded: "cloud" (manual Cloud API setup) or
  // "coexistence" (existing WhatsApp Business app number linked via Embedded
  // Signup — the phone app keeps working alongside the API).
  mode               String    @default("cloud")
  // connected | offboarded — flipped by account_offboarded/account_reconnected
  // webhooks for coexistence numbers.
  status             String    @default("connected")
  displayPhoneNumber String?   @map("display_phone_number") // human-readable, e.g. "+60 12-345 6789"
  accessToken        String    @map("access_token")
  autoReplyAgentId   String?   @map("auto_reply_agent_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("whatsapp_channels")
}

// Web-linked WhatsApp numbers paired via the messaging gateway (QR / pairing
// code). Control-plane (no RLS): gateway events resolve the workspace by
// sessionName before any tenant context exists.
model WaWebChannel {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  sessionName      String    @unique @map("session_name")
  phoneNumber      String?   @map("phone_number") // E.164, learned once paired
  displayName      String    @default("WhatsApp") @map("display_name")
  status           String    @default("starting") // starting | scan_qr | working | failed | logged_out | stopped
  autoReplyAgentId String?   @map("auto_reply_agent_id") @db.Uuid
  enabled          Boolean   @default(true)
  lastSeenAt       DateTime? @map("last_seen_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("wa_web_channels")
}

// Public-facing embeddable chat widget config (control-plane, no RLS — the
// public loader/chat resolves the workspace by publicKey without a session).
model WebWidget {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  publicKey        String    @unique @map("public_key")
  name             String    @default("Chat with us")
  color            String    @default("#FF7A59")
  welcomeMessage   String    @default("Hi! How can we help?") @map("welcome_message")
  autoReplyAgentId String?   @map("auto_reply_agent_id") @db.Uuid
  enabled          Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("web_widgets")
}

// API keys for the public REST API (control-plane, no RLS — requests authenticate
// by key, which resolves the workspace before any tenant context exists).
model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String
  prefix      String
  keyHash     String    @unique @map("key_hash")
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("api_keys")
}

// Outbound webhooks (control-plane). Dispatched from server actions that already
// hold the workspace context; payloads are HMAC-signed with the per-hook secret.
model Webhook {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  url         String
  secret      String
  events      String[]
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("webhooks")
}

// Meta (Facebook Page Messenger + Instagram DM + Lead Ads) and TikTok (Lead
// Generation) connections. Control-plane (no RLS): webhooks resolve the
// workspace by externalId before any tenant context exists.
model ChannelConnection {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  provider         String // "meta" | "tiktok"
  externalId       String    @map("external_id") // FB page id (meta) / advertiser id (tiktok)
  accessToken      String    @map("access_token")
  config           Json      @default("{}") // { igUserId?, appSecret?, pageName?, features:{messenger,instagram,leadgen} }
  autoReplyAgentId String?   @map("auto_reply_agent_id") @db.Uuid
  enabled          Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([workspaceId])
  @@map("channel_connections")
}

model Conversation {
  id              String             @id @default(uuid()) @db.Uuid
  workspaceId     String             @map("workspace_id") @db.Uuid
  channelType     String             @default("whatsapp") @map("channel_type")
  // Which channel row this conversation belongs to (polymorphic across
  // whatsapp_channels / wa_web_channels / channel_connections; null = legacy).
  channelId       String?            @map("channel_id") @db.Uuid
  contactId       String?            @map("contact_id") @db.Uuid
  customerPhone   String             @map("customer_phone")
  customerName    String?            @map("customer_name")
  status          ConversationStatus   @default(OPEN)
  priority        ConversationPriority @default(NONE)
  assignedAgentId String?              @map("assigned_agent_id") @db.Uuid
  assignedUserId  String?              @map("assigned_user_id") @db.Uuid
  snoozedUntil    DateTime?            @map("snoozed_until") @db.Timestamptz
  firstReplyAt    DateTime?            @map("first_reply_at") @db.Timestamptz
  waitingSince    DateTime?            @map("waiting_since") @db.Timestamptz
  customAttributes Json                @default("{}") @map("custom_attributes")
  lastMessageAt   DateTime             @default(now()) @map("last_message_at") @db.Timestamptz
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages        Message[]
  labels          ConversationLabel[]

  @@index([workspaceId, status, lastMessageAt])
  @@index([workspaceId, customerPhone])
  @@index([workspaceId, assignedUserId])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid()) @db.Uuid
  workspaceId    String           @map("workspace_id") @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  direction      MessageDirection
  body           String
  type           String           @default("text") // text | image | video | audio | document | sticker
  private        Boolean          @default(false) // internal note, not sent to the customer
  authorUserId   String?          @map("author_user_id") @db.Uuid
  mediaId        String?          @map("media_id")
  mediaMime      String?          @map("media_mime")
  mediaFilename  String?          @map("media_filename")
  waMessageId    String?          @map("wa_message_id")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([workspaceId, conversationId, createdAt])
  @@map("messages")
}

// ─────────────────────────── Workflow automation (RLS) ────────────────────────

model Workflow {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  name           String
  enabled        Boolean   @default(true)
  triggerType    String    @map("trigger_type")
  conditionField String?   @map("condition_field")
  conditionOp    String?   @map("condition_op")
  conditionValue String?   @map("condition_value")
  actionType     String    @map("action_type")
  actionAgentId  String?   @map("action_agent_id") @db.Uuid
  actionText     String?   @map("action_text")
  steps          Json      @default("[]") // ordered actions for the canvas builder: [{type, agentId?, text?}]
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs           WorkflowRun[]

  @@index([workspaceId, triggerType, enabled])
  @@map("workflows")
}

// Durable execution state for a workflow run. Most runs complete inline within
// the triggering request and are never persisted; a row is written only when a
// run must survive across requests — e.g. a Wait/Delay step (resumeAt) or a
// failed run kept for retry. The cron resume route scans WAITING + due rows.
model WorkflowRun {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  workflowId  String    @map("workflow_id") @db.Uuid
  status      String    @default("RUNNING") // RUNNING | WAITING | DONE | FAILED | CANCELLED
  pc          Int       @default(0) // program counter into the compiled instruction list
  context     Json      @default("{}") // serialized WorkflowContext + accumulated vars
  resumeAt    DateTime? @map("resume_at") @db.Timestamptz
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, resumeAt])
  @@index([workflowId])
  @@map("workflow_runs")
}

// Named, workspace-level merge variables ("custom values") usable in templates
// like {{customValue.businessName}} and writable by the "Update custom value"
// action.
model WorkspaceCustomValue {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  key         String
  value       String    @default("")
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@map("workspace_custom_values")
}

// Help center content is public-facing, so (like whatsapp_channels) it lives on
// the control plane — no RLS; every query filters workspaceId explicitly. This
// lets the unauthenticated public portal read articles without a tenant context.
model ArticleCategory {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String
  slug        String
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  articles    Article[]

  @@unique([workspaceId, slug])
  @@map("article_categories")
}

model Article {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @map("workspace_id") @db.Uuid
  categoryId  String?          @map("category_id") @db.Uuid
  title       String
  slug        String
  body        String
  published   Boolean          @default(false)
  position    Int              @default(0)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
