# ── Database (Neon Postgres recommended on Vercel) ───────────────────────────
# Pooled connection (used at runtime by serverless functions)
DATABASE_URL="postgresql://user:password@host/clevar?sslmode=require"
# Direct connection (used by `prisma migrate` — Neon: the non-pooled host)
DIRECT_URL="postgresql://user:password@host/clevar?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────────────
# 32+ char random secret used to sign session JWTs. Generate: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the deployment (used for invite links). No trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── WhatsApp Business app connect (Coexistence, optional) ────────────────────
# One-click "Connect WhatsApp Business app" via Meta Embedded Signup. Needs an
# approved Meta app (Tech Provider) — full runbook: docs/meta-coexistence-approval.md.
# Feature stays hidden until all three are set.
# NEXT_PUBLIC_META_APP_ID="your-meta-app-id"
# META_APP_SECRET="your-meta-app-secret"
# NEXT_PUBLIC_META_ES_CONFIG_ID="your-embedded-signup-configuration-id"
# Webhook credentials (shared with the manual Cloud API setup):
# WHATSAPP_VERIFY_TOKEN="any-random-string-you-also-paste-into-meta"
# WHATSAPP_APP_SECRET="same-as-META_APP_SECRET-for-signature-checks"

# ── AI (agents + knowledge retrieval) ────────────────────────────────────────
# LLM replies (at least one required for AI agents to respond):
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."          # only for the GPT model option
# Semantic knowledge retrieval (optional — without it, search is lexical-only):
# voyage-3.5 embeddings + rerank-2.5-lite, https://dash.voyageai.com
# VOYAGE_API_KEY="pa-..."

# ── Scheduler ────────────────────────────────────────────────────────────────
# Secret for /api/cron (workflow Wait/Drip resume, scheduled triggers, embedding
# backfill). Vercel Cron sends it as a Bearer token automatically once set.
# CRON_SECRET="any-long-random-string"
