# ── Database (Neon Postgres recommended on Vercel) ───────────────────────────
# Pooled connection (used at runtime by serverless functions)
DATABASE_URL="postgresql://user:password@host/clevar?sslmode=require"
# Direct connection (used by `prisma migrate` — Neon: the non-pooled host)
DIRECT_URL="postgresql://user:password@host/clevar?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────────────
# 32+ char random secret used to sign session JWTs. Generate: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the deployment (used for invite links). No trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
